# Secrets / credentials
.env
*.env.local

# Runtime artefacts (auto-generated, don't commit)
logs/
public_url.txt
# Retired Windsor artefacts (kept as *.deprecated locally, never committed)
data/windsor_cache*
data/windsor_*.json*
scripts/*.deprecated

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Virtual envs (never commit — huge + machine-specific)
venv/
venv_claude/
.venv/

# Tunnels / binaries (download fresh on each machine)
cloudflared.exe

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/

# Vercel local cache
.vercel/

# Playwright auth (sensitive — never commit)
config/playwright_storage_*.json
config/chrome_profile_*/

# Cloned Chrome profiles (large, contain session tokens — never commit)
chrome_profiles/
config/chrome_debug_profile/
